#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${SENTINEL_FIRMWARE_UPDATER_STATE_DIR:-/var/lib/sentinel_rtp_cam/firmware-updater}"
REQUEST_DIR="${STATE_DIR}/requests"
RESULT_DIR="${STATE_DIR}/results"
WAIT_TIMEOUT_SECONDS="${SENTINEL_FIRMWARE_UPDATER_TIMEOUT:-900}"

show_usage() {
    cat <<'EOF'
Usage: sentinel-firmware-update <version|latest> [--start]
       sentinel-firmware-update --rollback [--start]

Agent firmware updater request wrapper.

Installs as: /usr/local/bin/sentinel-firmware-update
Default agent config: FIRMWARE_UPDATER_CMD=/usr/local/bin/sentinel-firmware-update
Version file written by successful updates: /etc/sentinel_rtp_cam/firmware-version

Examples:
  sentinel-firmware-update 1.1.3
  sentinel-firmware-update 1.1.3 --start
  sentinel-firmware-update latest
  sentinel-firmware-update --rollback
  sentinel-firmware-update --rollback --start

Notes:
  - This command is unprivileged; a root-owned systemd service performs the update.
  - --start schedules a delayed restart after the update result is written.
  - Rollback is not currently implemented by sentinel-tooling.
EOF
}

die() {
    echo "[sentinel-firmware-update] $*" >&2
    exit 1
}

normalize_version() {
    local version="$1"

    if [[ "$version" == "latest" ]]; then
        printf '%s\n' "$version"
        return
    fi

    version="${version#v}"
    if [[ -z "$version" || "$version" == -* || ! "$version" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
        return 1
    fi

    printf '%s\n' "$version"
}

ensure_queue_ready() {
    if [[ ! -d "$REQUEST_DIR" || ! -w "$REQUEST_DIR" ]]; then
        die "Firmware updater request queue is not available at $REQUEST_DIR. Install managed firmware updater support first."
    fi

    if [[ ! -d "$RESULT_DIR" || ! -r "$RESULT_DIR" || ! -x "$RESULT_DIR" ]]; then
        die "Firmware updater result directory is not available at $RESULT_DIR. Install managed firmware updater support first."
    fi
}

write_request() {
    local version="$1"
    local start_after="$2"
    local request_id="$3"
    local request_path="${REQUEST_DIR}/${request_id}.req"
    local tmp_request

    tmp_request="$(mktemp "${REQUEST_DIR}/.sentinel-firmware-update.${request_id}.XXXXXX")"
    {
        printf 'action=update\n'
        printf 'version=%s\n' "$version"
        printf 'start=%s\n' "$start_after"
    } > "$tmp_request"
    mv -f "$tmp_request" "$request_path"

    printf '%s\n' "$request_path"
}

read_result() {
    local result_path="$1"
    local exit_code=""
    local message=""
    local log_path=""

    while IFS= read -r line; do
        case "$line" in
            exit_code=*)
                exit_code="${line#exit_code=}"
                ;;
            message=*)
                message="${line#message=}"
                ;;
            log_path=*)
                log_path="${line#log_path=}"
                ;;
        esac
    done < "$result_path"

    if [[ -z "$exit_code" ]]; then
        die "Dispatcher returned an invalid result file: $result_path"
    fi

    if [[ -n "$message" ]]; then
        if [[ "$exit_code" == "0" ]]; then
            echo "$message"
        else
            echo "$message" >&2
        fi
    fi

    if [[ "$exit_code" != "0" && -n "$log_path" && -f "$log_path" ]]; then
        cat "$log_path" >&2
    fi

    exit "$exit_code"
}

wait_for_result() {
    local request_id="$1"
    local result_path="${RESULT_DIR}/${request_id}.result"
    local waited=0

    while (( waited < WAIT_TIMEOUT_SECONDS )); do
        if [[ -f "$result_path" ]]; then
            read_result "$result_path"
        fi
        sleep 1
        waited=$((waited + 1))
    done

    die "Timed out waiting for the root firmware updater dispatcher. Check sentinel-firmware-update-dispatch.path and sentinel-firmware-update-dispatch.service."
}

main() {
    local target_version=""
    local normalized_version=""
    local start_after=0
    local rollback=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --start)
                start_after=1
                ;;
            --rollback)
                rollback=1
                ;;
            --help|-h|help)
                show_usage
                exit 0
                ;;
            --*)
                die "Unknown option: $1"
                ;;
            *)
                if [[ -n "$target_version" ]]; then
                    die "Unexpected extra argument: $1"
                fi
                target_version="$1"
                ;;
        esac
        shift
    done

    if [[ $rollback -eq 1 ]]; then
        if [[ -n "$target_version" ]]; then
            die "Do not pass a target version with --rollback."
        fi
        die "Rollback is not supported by sentinel-tooling yet. Existing update flow only creates .prev backups; no rollback command is implemented."
    fi

    if [[ -z "$target_version" ]]; then
        show_usage >&2
        exit 1
    fi

    if ! normalized_version="$(normalize_version "$target_version")"; then
        die "Unsupported target version: $target_version"
    fi

    ensure_queue_ready

    local request_id
    request_id="$(date +%s)-$$-${RANDOM}"
    write_request "$normalized_version" "$start_after" "$request_id" >/dev/null
    wait_for_result "$request_id"
}

main "$@"
